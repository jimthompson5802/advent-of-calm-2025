{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Company Relationship Standard",
  "allOf": [
    {
      "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship"
    },
    {
      "type": "object",
      "properties": {
        "dataClassification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"],
          "description": "Data classification for the relationship's data flow."
        },
        "encrypted": {
          "type": "boolean",
          "description": "Indicates whether the connection is encrypted in transit."
        }
      },
      "required": ["dataClassification", "encrypted"]
    }
  ]
}