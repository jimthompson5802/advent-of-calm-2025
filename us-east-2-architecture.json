        {
          "unique-id": "inventory-service-backup-db-client",
          "protocol": "JDBC"
        }
      ]
    },
    {
      "unique-id": "payment-service-backup",
      "node-type": "service",
      "name": "Payment Service Backup",
      "description": "Authorizes and captures payments for orders.",
      "metadata": {
        "owner": "payments-team",
        "oncall-slack": "#oncall-payments",
        "health-endpoint": "/health",
        "runbook": "https://runbooks.example.com/payment-service",
        "tier": "tier-1",
        "dependencies": [
          "message-broker-backup"
        ],
        "dashboard": "https://grafana.example.com/d/payment-service",
        "log-query": "service:payment-service",
        "alerts": [
          "Payment Service Error Rate",
          "Payment Processing Backlog"
        ],
        "failure-modes": [
          {
            "symptom": "Payment processing backlog",
            "likely-cause": "Consumer lag or broker throttling",
            "check": "Check queue depth and consumer lag in broker dashboard",
            "remediation": "Scale payment-service consumers",
            "escalation": "Contact platform-team if broker throttling persists"
          }
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "runtime": "nodejs",
        "sla-tier": "tier-1"
      },
      "controls": {
        "compliance": {
          "description": "PCI-DSS compliance for payment processing",
          "requirements": [
            {
              "requirement-url": "https://www.pcisecuritystandards.org/documents/PCI-DSS-v4.0",
              "config-url": "https://configs.example.com/compliance/pci-dss-config.json"
            }
          ]
        }
      },
      "interfaces": [
        {
          "unique-id": "payment-service-backup-http",
          "host": "payment-service-backup.internal",
          "port": 8082,
          "basePath": "/payments",
          "authentication": "mTLS"
        }
      ]
    },
    {
      "unique-id": "message-broker-backup",
      "node-type": "system",
      "name": "Message Broker Backup",
