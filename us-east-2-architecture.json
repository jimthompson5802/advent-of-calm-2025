        "engine": "postgresql",
        "backup-schedule": "daily 03:00 UTC",
        "restore-time": "45m",
        "dba-contact": "dba-inventory@example.com"
      },
      "interfaces": [
        {
          "unique-id": "inventory-db-backup-jdbc",
          "protocol": "JDBC",
