{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "unique-id": "us-east-2-architecture",
  "name": "US East 2 Architecture",
  "description": "US East 2 backup deployment with disaster recovery setup and cross-region replication from US East 1",
  "metadata": {
    "owner": "github-copilot@example.com",
    "version": "1.0.0",
    "created": "2026-03-15",
    "description": "US East 2 backup deployment with US East 1 primary components",
    "tags": [
      "backup",
      "disaster-recovery",
      "us-east-2",
      "us-east-1",
      "multi-region"
    ],
    "region": "us-east-2"
  },
  "nodes": [
    {
      "unique-id": "ecommerce-platform-system",
      "node-type": "system",
      "name": "E-Commerce Platform",
      "description": "System boundary containing the order processing microservices.",
      "metadata": {
        "owner": "Platform Architecture",
        "repository": "https://example.com/repo",
        "deployment-type": "cloud"
      }
    },
    {
      "unique-id": "order-database-cluster",
      "node-type": "system",
      "name": "Order Database Cluster",
      "description": "Cluster containing primary and replica order databases.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "replication-mode": "async"
      },
      "controls": {
        "failover": {
          "description": "Failover and recovery objectives for the order database cluster.",
          "requirements": [
            {
              "requirement-url": "https://internal-policy.example.com/resilience/failover",
              "config": {
                "rto": "15m",
                "rpo": "5m",
                "failover-mode": "automatic"
              }
            }
          ]
        }
      }
    },
    {
      "unique-id": "order-database-primary",
      "node-type": "database",
      "name": "Order Database Primary",
      "description": "Primary store for order state, line items, and order history.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "engine": "postgresql",
        "role": "primary",
        "replication-mode": "async",
        "backup-schedule": "daily 02:00 UTC",
        "restore-time": "30m",
        "dba-contact": "dba-orders@example.com"
      },
      "interfaces": [
        {
          "unique-id": "order-db-primary-jdbc",
          "protocol": "JDBC",
          "host": "order-db-primary.internal",
          "port": 5432,
          "database": "orders"
        }
      ]
    },
    {
      "unique-id": "order-database-replica",
      "node-type": "database",
      "name": "Order Database Replica",
      "description": "Read replica for order queries.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "engine": "postgresql",
        "role": "replica",
        "replication-mode": "async",
        "backup-schedule": "daily 02:00 UTC",
        "restore-time": "45m",
        "dba-contact": "dba-orders@example.com"
      },
      "interfaces": [
        {
          "unique-id": "order-db-replica-jdbc",
          "protocol": "JDBC",
          "host": "order-db-replica.internal",
          "port": 5432,
          "database": "orders"
        }
      ]
    },
    {
      "unique-id": "order-database-cluster-secondary",
      "node-type": "system",
      "name": "Order Database Cluster Secondary",
      "description": "Secondary cluster containing order database replicas for disaster recovery.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "replication-mode": "async"
      }
    },
    {
      "unique-id": "order-database-secondary",
      "node-type": "database",
      "name": "Order Database Secondary",
      "description": "Secondary database for order data in disaster recovery region.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "engine": "postgresql",
        "role": "secondary",
        "replication-mode": "async",
        "backup-schedule": "daily 02:00 UTC",
        "restore-time": "30m",
        "dba-contact": "dba-orders@example.com"
      },
      "interfaces": [
        {
          "unique-id": "order-db-secondary-jdbc",
          "protocol": "JDBC",
          "host": "order-db-secondary.internal",
          "port": 5432,
          "database": "orders"
        }
      ]
    },
    {
      "unique-id": "order-database-replica-secondary",
      "node-type": "database",
      "name": "Order Database Replica Secondary",
      "description": "Read replica for secondary order database.",
      "metadata": {
        "owner": "Orders Team",
        "repository": "https://example.com/repo",
        "deployment-type": "managed-database",
        "engine": "postgresql",
        "role": "replica",
        "replication-mode": "async",
        "backup-schedule": "daily 02:00 UTC",
        "restore-time": "45m",
        "dba-contact": "dba-orders@example.com"
      },
      "interfaces": [
        {
          "unique-id": "order-db-replica-secondary-jdbc",
          "protocol": "JDBC",
          "host": "order-db-replica-secondary.internal",
          "port": 5432,
          "database": "orders"
        }
      ]
    },
    {
      "unique-id": "us-east-1",
      "node-type": "network",
      "name": "US East 1",
      "description": "AWS US East 1 (N. Virginia) network region"
    },
    {
      "unique-id": "us-east-2",
      "node-type": "network",
      "name": "US East 2",
      "description": "AWS US East 2 (Ohio) network region"
    },
    {
      "unique-id": "ecommerce-platform-system-backup",
      "node-type": "system",
      "name": "E-Commerce Platform Backup",
      "description": "Backup system boundary containing backup instances of the order processing microservices.",
      "metadata": {
        "owner": "Platform Architecture",
        "repository": "https://example.com/repo",
        "deployment-type": "cloud"
      }
    },
    {
      "unique-id": "load-balancer-backup",
      "node-type": "service",
      "name": "Load Balancer Backup",
      "description": "Entry point distributing traffic across API Gateway instances.",
      "metadata": {
        "owner": "platform-team",
        "oncall-slack": "#oncall-platform",
        "health-endpoint": "/health",
        "runbook": "https://runbooks.example.com/load-balancer",
        "tier": "tier-1",
        "dependencies": [
          "api-gateway-1-backup",
          "api-gateway-2-backup"
        ],
        "dashboard": "https://grafana.example.com/d/load-balancer",
        "log-query": "service:load-balancer",
        "alerts": [
          "LB High Error Rate",
          "LB Target Unhealthy"
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "managed",
        "ha-enabled": true
      },
      "interfaces": [
        {
          "unique-id": "load-balancer-backup-public-https",
          "url": "https://api-backup.example.com",
          "authentication": "OAuth2"
        }
      ]
    },
    {
      "unique-id": "api-gateway-1-backup",
      "node-type": "service",
      "name": "API Gateway Backup",
      "description": "Edge service providing a single entry point for customer and admin requests.",
      "metadata": {
        "owner": "platform-team",
        "oncall-slack": "#oncall-platform",
        "health-endpoint": "/health",
        "runbook": "https://runbooks.example.com/api-gateway",
        "tier": "tier-1",
        "dependencies": [
          "order-service-backup",
          "inventory-service-backup"
        ],
        "dashboard": "https://grafana.example.com/d/api-gateway",
        "log-query": "service:api-gateway AND instance:api-gateway-1",
        "alerts": [
          "API Gateway 5xx Spike",
          "API Gateway Latency High"
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "runtime": "nginx",
        "sla-tier": "tier-1",
        "ha-enabled": true
      },
      "controls": {
        "performance": {
          "description": "API Gateway rate limiting and caching requirements",
          "requirements": [
            {
              "requirement-url": "https://internal-policy.example.com/performance/rate-limiting",
              "config-url": "https://configs.example.com/gateway/rate-limits.yaml"
            },
            {
              "requirement-url": "https://internal-policy.example.com/performance/caching-policy",
              "config": {
                "default-ttl-seconds": 300,
                "cache-control": "private"
              }
            }
          ]
        }
      },
      "interfaces": [
        {
          "unique-id": "api-gateway-1-backup-internal-https",
          "host": "api-gateway-1-backup.internal",
          "port": 8443,
          "authentication": "mTLS"
        }
      ]
    },
    {
      "unique-id": "api-gateway-2-backup",
      "node-type": "service",
      "name": "API Gateway Backup",
      "description": "Edge service providing a single entry point for customer and admin requests.",
      "metadata": {
        "owner": "platform-team",
        "oncall-slack": "#oncall-platform",
        "health-endpoint": "/health",
        "runbook": "https://runbooks.example.com/api-gateway",
        "tier": "tier-1",
        "dependencies": [
          "order-service-backup",
          "inventory-service-backup"
        ],
        "dashboard": "https://grafana.example.com/d/api-gateway",
        "log-query": "service:api-gateway AND instance:api-gateway-2",
        "alerts": [
          "API Gateway 5xx Spike",
          "API Gateway Latency High"
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "runtime": "nginx",
        "sla-tier": "tier-1",
        "ha-enabled": true
      },
      "controls": {
        "performance": {
          "description": "API Gateway rate limiting and caching requirements",
          "requirements": [
            {
              "requirement-url": "https://internal-policy.example.com/performance/rate-limiting",
              "config-url": "https://configs.example.com/gateway/rate-limits.yaml"
            },
            {
              "requirement-url": "https://internal-policy.example.com/performance/caching-policy",
              "config": {
                "default-ttl-seconds": 300,
                "cache-control": "private"
              }
            }
          ]
        }
      },
      "interfaces": [
        {
          "unique-id": "api-gateway-2-backup-internal-https",
          "host": "api-gateway-2-backup.internal",
          "port": 8443,
          "authentication": "mTLS"
        }
      ]
    },
    {
      "unique-id": "order-service-backup",
      "node-type": "service",
      "name": "Order Service Backup",
      "description": "Creates and manages customer orders, orchestrating inventory reservation and payment authorization.",
      "metadata": {
        "owner": "orders-team",
        "oncall-slack": "#oncall-orders",
        "health-endpoint": "/actuator/health",
        "runbook": "https://runbooks.example.com/order-service",
        "tier": "tier-1",
        "dependencies": [
          "message-broker-backup"
        ],
        "dashboard": "https://grafana.example.com/d/order-service",
        "log-query": "service:order-service",
        "alerts": [
          "Order Service Error Rate",
          "Order Service Latency High"
        ],
        "failure-modes": [
          {
            "symptom": "HTTP 503 errors",
            "likely-cause": "Database connection pool exhausted",
            "check": "Check connection pool metrics in Grafana dashboard",
            "remediation": "Scale up connection pool or add service instances",
            "escalation": "Page orders-team lead if issue persists after scaling"
          }
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "runtime": "java",
        "sla-tier": "tier-1"
      },
      "controls": {
        "circuit-breaker": {
          "description": "Failure isolation thresholds for downstream calls.",
          "requirements": [
            {
              "requirement-url": "https://internal-policy.example.com/resilience/circuit-breaker",
              "config": {
                "failure-rate-percent": 50,
                "min-requests": 20,
                "open-state-duration": "30s",
                "half-open-max-requests": 5
              }
            }
          ]
        }
      },
      "interfaces": [
        {
          "unique-id": "order-service-backup-http",
          "host": "order-service-backup.internal",
          "port": 8080,
          "basePath": "/orders",
          "authentication": "mTLS"
        },
        {
          "unique-id": "order-service-backup-db-client",
          "protocol": "JDBC",
          "description": "Outbound JDBC client interface used to access the Order Database."
        }
      ]
    },
    {
      "unique-id": "inventory-service-backup",
      "node-type": "service",
      "name": "Inventory Service Backup",
      "description": "Tracks stock levels and reserves inventory for confirmed orders.",
      "metadata": {
        "owner": "inventory-team",
        "oncall-slack": "#oncall-inventory",
        "health-endpoint": "/health",
        "runbook": "https://runbooks.example.com/inventory-service",
        "tier": "tier-2",
        "dependencies": [
          "inventory-database-backup"
        ],
        "dashboard": "https://grafana.example.com/d/inventory-service",
        "log-query": "service:inventory-service",
        "alerts": [
          "Inventory Service Error Rate"
        ],
        "failure-modes": [
          {
            "symptom": "Inventory reservation failures",
            "likely-cause": "Database connectivity or lock contention",
            "check": "Check database metrics and active transactions",
            "remediation": "Clear stale locks or restart service",
            "escalation": "Contact inventory-team if data corruption suspected"
          }
        ],
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "runtime": "go",
        "sla-tier": "tier-2"
      },
      "interfaces": [
        {
          "unique-id": "inventory-service-backup-http",
          "host": "inventory-service-backup.internal",
          "port": 8081
