{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "unique-id": "my-first-architecture",
  "name": "My First Architecture",
  "description": "A minimal CALM architecture containing a single customer authentication service.",
  "metadata": {
    "owner": "Architecture Team",
    "version": "1.0.0",
    "created": "2026-03-15",
    "description": "authentication service",
    "tags": ["learning", "authentication", "demo"]
  },
  "nodes": [
    {
      "unique-id": "customer-authentication-service",
      "node-type": "service",
      "name": "Customer Authentication Service",
      "description": "Validates user credentials and manages session tokens.",
      "metadata": {
        "tech-owner": "The Tech Team",
        "repository": "https://example.com/repo",
        "deployment-type": "container",
        "sla-tier": "tier-1"
      },
      "interfaces": [
        {
          "unique-id": "customer-auth-api",
          "definition-url": "https://my-enterprise/patterns/rest-api-interface.json",
          "config": {
            "host": "api.example.com",
            "port": 443,
            "basePath": "/api/v1",
            "authentication": "None"
          }
        }
      ]
    },
    {
      "unique-id": "customer-authentication-database",
      "node-type": "database",
      "name": "Customer Authentication Database",
      "description": "Stores customer authentication data for the Customer Authentication Service.",
      "interfaces": [
        {
          "unique-id": "customer-auth-db-jdbc",
          "protocol": "JDBC",
          "host": "db.example.com",
          "port": 5432,
          "database": "customer_auth"
        }
      ]
    },
    {
      "unique-id": "customer",
      "node-type": "actor",
      "name": "Customer",
      "description": "End user who uses the Customer Authentication Service."
    },
    {
      "unique-id": "customer-authentication-system",
      "node-type": "system",
      "name": "Customer Authentication System",
      "description": "Overall system containing the customer authentication service and its database."
    }
  ],
  "relationships": [
    {
      "unique-id": "customer-authentication-system-composed-of",
      "description": "System is composed of the authentication service and database.",
      "relationship-type": {
        "composed-of": {
          "container": "customer-authentication-system",
          "nodes": [
            "customer-authentication-service",
            "customer-authentication-database"
          ]
        }
      }
    },
    {
      "unique-id": "customer-interacts-with-auth-service",
      "description": "Customer interacts with the Customer Authentication Service.",
      "relationship-type": {
        "interacts": {
          "actor": "customer",
          "nodes": ["customer-authentication-service"]
        }
      }
    },
    {
      "unique-id": "auth-service-connects-auth-db",
      "description": "Connects to the database for storing and retrieving authentication data.",
      "metadata": {
        "latency-sla": "< 100ms",
        "monitoring": true,
        "circuit-breaker": true
      },
      "relationship-type": {
        "connects": {
          "source": {
            "node": "customer-authentication-service",
            "interfaces": ["customer-auth-api"]
          },
          "destination": {
            "node": "customer-authentication-database",
            "interfaces": ["customer-auth-db-jdbc"]
          }
        }
      }
    }
  ]
}
